# hbar brain layer - Environment Configuration Example
# Copy this file to .env and adjust values as needed

# Application Environment
APP_ENV=dev
TZ=Europe/Berlin

# PostgreSQL Database (existing system)
POSTGRES_HOST=localhost
POSTGRES_PORT=54322
POSTGRES_DB=llm_db
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

# Ollama Configuration
# Toggle between host Ollama (host.docker.internal:11434) and container Ollama (ollama:11434)
OLLAMA_BASE=host.docker.internal:11434
# OLLAMA_BASE=ollama:11434
OLLAMA_MODEL=llama3.2:1b
DEFAULT_MODEL=llama3.2:1b

# API Configuration
API_BASE=http://localhost:8000

# Document Processing Configuration
CHUNK_SIZE=750
CHUNK_OVERLAP=150

# Document Ingestion
DOCS_DIR_HOST=/path/to/my/notes

# Optional: Admin token for document management endpoints
# ADMIN_TOKEN=your-secret-admin-token

# Optional: Semantic Database Path (defaults to extensions/brain/semantic.db)
# SEMANTIC_DB_PATH=/custom/path/to/semantic.db
