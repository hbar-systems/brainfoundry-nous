# Environment Configuration Example
# Copy this file to .env and fill in all values before starting.
#
# QUICK START:
#   cp .env.example .env
#   nano .env    ← fill in secrets and identity fields
#   docker compose up -d --build

# ─── Environment ──────────────────────────────────────────────────────────────
# Set to "prod" to enable startup secret enforcement.
# In prod mode, the API refuses to start if any secret is missing or default.
BRAIN_ENV=dev

TZ=UTC

# ─── Brain Identity ───────────────────────────────────────────────────────────
BRAIN_ID=my-brain-01
BRAIN_NAME=My Brain
BRAIN_SYMBOL=⊕
BRAIN_OWNER=Your Name

# ─── Required Secrets ─────────────────────────────────────────────────────────
# Generate each with: openssl rand -hex 32
BRAIN_API_KEY=
BRAIN_IDENTITY_SECRET=
NODEOS_SIGNING_SECRET=
# Service-to-service key. The brain API forwards this as X-Internal-Key on every
# call to NodeOS. NodeOS rejects state-mutating requests without a match.
# Required in prod (BRAIN_ENV=prod); strongly recommended in dev.
NODEOS_INTERNAL_KEY=

# ─── Federation Keypair (ED25519) ─────────────────────────────────────────────
# Generate once: python scripts/generate_keypair.py
# BRAIN_PRIVATE_KEY is secret — never share, never commit.
# BRAIN_PUBLIC_KEY is public — published via GET /identity so other brains can verify your tokens.
BRAIN_PRIVATE_KEY=
BRAIN_PUBLIC_KEY=

# ─── PostgreSQL ───────────────────────────────────────────────────────────────
# Change POSTGRES_USER and POSTGRES_PASSWORD before production deployment.
POSTGRES_DB=llm_db
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

# ─── Ollama ───────────────────────────────────────────────────────────────────
# Local generation budget. Ollama's default num_ctx (4096) reserves nothing for
# output; with RAG the prompt can fill the whole window and starve generation.
OLLAMA_NUM_CTX=8192
OLLAMA_NUM_PREDICT=512

# ─── Default model resolution ─────────────────────────────────────────────────
# Leave OLLAMA_MODEL / DEFAULT_MODEL UNSET (below) to enable key-aware default
# resolution: when a chat names no model and the operator has made no explicit
# choice, the brain defaults to a BYOK frontier reasoner IF any cloud key is
# configured (memory/RAG stay sovereign on the brain — only the reasoner is
# remote), otherwise it falls back to LOCAL_FALLBACK_MODEL. The public/unauth
# chat surface always stays local regardless.
#
# Set either of these to PIN a specific default and bypass the key-aware logic:
#   DEFAULT_MODEL=llama3.2:3b      # hard-pin a model for this brain
#   OLLAMA_MODEL=llama3.2:3b       # also serves as the active-model identity
BYOK_DEFAULT_MODEL=claude-opus-4-8
LOCAL_FALLBACK_MODEL=llama3.2:3b

# ─── RAG context budget (per retrieval) ───────────────────────────────────────
# Cloud/BYOK: count cap only, full document bodies kept. Local tiny model: hard
# fit-budget so the prompt cannot overflow the context window.
RAG_MAX_DOCS_CLOUD=6
RAG_MAX_DOCS_LOCAL=5
RAG_PER_DOC_CHARS=1500
RAG_CONTEXT_CHAR_BUDGET=7000
RAG_MIN_SIMILARITY=0.0

# ─── Model API Keys (set only the providers you want to use) ──────────────────
# Ollama is always available and requires no key.
# ANTHROPIC_API_KEY=
# OPENAI_API_KEY=
# GOOGLE_API_KEY=
# XAI_API_KEY=
# GROQ_API_KEY=
# OPENROUTER_API_KEY=

# ─── Tools: Web Search (optional, YELLOW tier) ───────────────────────────────
# Brave Search API key. Lets the brain read the open web (read-only, untrusted,
# off by default). Can also be set at runtime in Settings → Web search (stored
# on the brain's sidecar, no restart). Get a key: https://brave.com/search/api/
# BRAVE_SEARCH_API_KEY=

# ─── Document Processing ──────────────────────────────────────────────────────
CHUNK_SIZE=750
CHUNK_OVERLAP=150
# DOCS_DIR_HOST=          # optional: default folder for scripts/ingest_folder.py

# ─── RAG Tier Folder Names (optional) ────────────────────────────────────────
# The brain gives priority to documents from these folders during search.
# Change to match how you've organized your corpus.
# RAG_TIER1=identity
# RAG_TIER2A=thinking
# RAG_TIER2B=projects
# RAG_TIER2C=writing

# ─── BrainKernel (NodeOS) — optional governance controls ─────────────────────
# Comma-separated list of branches NodeOS is allowed to push to via git.
# Leave empty to disable all push operations.
# NODEOS_PUSH_BRANCH_ALLOWLIST=

# Comma-separated branch-name prefixes NodeOS may push to (e.g. nodeos/).
# NODEOS_PUSH_BRANCH_PREFIX_ALLOWLIST=nodeos/

# Absolute path on the host that NodeOS can write files to (workspace root).
# NODEOS_WORKSPACE_ROOT=/var/lib/brainfoundry/workspace

# ─── Federation Substrate Floor (Layer 1) ────────────────────────────────────
# A new brain cannot federate with this one until its substrate-depth signal
# clears these thresholds. See:
#   hbar.world/discussions/2026-05-01_federation-trust-mechanisms.md
# Defaults below are the prompt's starting points (untested, env-tunable).
# Set FEDERATION_SUBSTRATE_GATE=off to disable the gate (rolls back to the
# pre-Layer-1 handshake behavior). The /v1/federation/substrate-depth endpoint
# remains served regardless of the gate setting.
# FEDERATION_SUBSTRATE_GATE=on
# FEDERATION_SUBSTRATE_MIN_ARTIFACTS=50
# FEDERATION_SUBSTRATE_MIN_FIRST_PERSON=25
# FEDERATION_SUBSTRATE_MIN_DIVERSITY=2
# FEDERATION_SUBSTRATE_MIN_AGE_DAYS=7
# SUBSTRATE_DEPTH_CACHE_SECONDS=300
# SUBSTRATE_PEER_CACHE_SECONDS=300

# ─── Network ──────────────────────────────────────────────────────────────────
API_BASE=http://localhost:8010

# Additional CORS origins (comma-separated, e.g. your console domain)
# CORS_ORIGINS=https://console.yourbrain.example.com
