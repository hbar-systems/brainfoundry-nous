# Environment Configuration Example
# Copy this file to .env and adjust values as needed

# Application Environment
APP_ENV=dev
TZ=Europe/Berlin

# PostgreSQL Database (existing system)
POSTGRES_HOST=localhost
POSTGRES_PORT=54322
POSTGRES_DB=llm_db
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

# Ollama Configuration
# Toggle between host Ollama (host.docker.internal:11434) and container Ollama (ollama:11434)
OLLAMA_BASE=host.docker.internal:11434
# OLLAMA_BASE=ollama:11434
OLLAMA_MODEL=llama3.2:1b
DEFAULT_MODEL=llama3.2:1b

# API Configuration
API_BASE=http://localhost:8000

# Document Processing Configuration
CHUNK_SIZE=750
CHUNK_OVERLAP=150

# Document Ingestion
DOCS_DIR_HOST=/path/to/my/notes

# RAG Tier Folder Names (optional — rename to match your corpus structure)
# Tier 1 (identity/context): always injected first (2 results)
# Tier 2 (active domains):   always injected next (1 result each)
# Tier 3: general similarity search over everything else
# RAG_TIER1=identity
# RAG_TIER2A=thinking
# RAG_TIER2B=projects
# RAG_TIER2C=writing

# Optional: Admin token for document management endpoints
# ADMIN_TOKEN=your-secret-admin-token

# Optional: Semantic Database Path (defaults to extensions/brain/semantic.db)
# SEMANTIC_DB_PATH=/custom/path/to/semantic.db

# Additional CORS origins (comma-separated, e.g. your console domain)
# CORS_ORIGINS=https://console.yourbrain.example.com

# Federation keypair (ED25519 — asymmetric signing for cross-brain assertions)
# Generate once: python scripts/generate_keypair.py
# BRAIN_PRIVATE_KEY is secret — never share, never commit.
# BRAIN_PUBLIC_KEY is public — published via GET /identity so other brains can verify your tokens.
BRAIN_PRIVATE_KEY=
BRAIN_PUBLIC_KEY=

